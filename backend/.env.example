FLASK_APP=app:create_app
FLASK_ENV=development
FLASK_DEBUG=1

# Security
SECRET_KEY=replace-this-with-a-very-strong-secret-key-in-production

# Database (PostgreSQL Ready, default to SQLite for dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/ecopilot
DATABASE_URL=sqlite:///ecopilot_dev.db

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
